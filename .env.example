# Environment configuration example
# Copy this file to .env and fill in the actual values

# Application environment
APP_ENV=dev

# Database configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=shaanxi_resilience

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=outputs/logs

# Pipeline settings
PIPELINE_DEFAULT_MODE=full
PIPELINE_OVERWRITE=false

# Query API settings
API_HOST=0.0.0.0
API_PORT=8010
API_RELOAD=true
